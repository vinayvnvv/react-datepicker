{
  "name": "@punaro/react-datepicker",
  "version": "0.0.2",
  "description": "A lightweight, accessible React date picker component",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    },
    "./styles.css": "./dist/styles.css"
  },
  "files": [
    "dist"
  ],
  "sideEffects": [
    "./dist/styles.css"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build && cp src/styles.css dist/styles.css",
    "build:watch": "vite build --watch",
    "preview": "vite preview",
    "lint": "eslint src --ext .ts,.tsx",
    "deploy:gh": "gh-pages -d distExamples"
  },
  "keywords": [
    "react",
    "datepicker",
    "date-picker",
    "calendar",
    "component"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/vinayvnvv/react-datepicker.git"
  },
  "bugs": {
    "url": "https://github.com/vinayvnvv/react-datepicker/issues"
  },
  "homepage": "https://github.com/vinayvnvv/react-datepicker#readme",
  "peerDependencies": {
    "react": ">=17.0.0",
    "react-dom": ">=17.0.0"
  },
  "dependencies": {
    "date-fns": "^3.6.0"
  },
  "devDependencies": {
    "@types/node": "^25.7.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^5.0.0",
    "gh-pages": "^6.3.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.5.0",
    "vite": "^8.0.12",
    "vite-plugin-dts": "^4.0.0"
  }
}
